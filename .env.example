PORT=3000
NODE_ENV=development

# Public base URL for image links in API responses (no trailing slash)
# Example: http://localhost:3002 or https://api.yourdomain.com
APP_PUBLIC_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/office_management

# Auth
JWT_SECRET=replace_me_with_a_long_random_secret
BOOTSTRAP_SUPER_ADMIN_KEY=replace_me_for_first_admin_setup_only
